# Environment Variables Example

# Database
DATABASE_URL="postgres://..."
DIRECT_URL="postgres://..."

# Supabase
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Auth
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Resend
RESEND_API_KEY="re_..."
# Verified sender for capsule unlock emails. Falls back to onboarding@resend.dev.
RESEND_FROM_EMAIL="Time Capsule <noreply@your-verified-domain.com>"

# Upstash (Rate Limiting)
UPSTASH_REDIS_REST_URL="https://..."
UPSTASH_REDIS_REST_TOKEN="..."

# Security
MASTER_KEK="base64-encoded-256-bit-key"
CRON_SECRET="random-uuid"
